rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          ('email' in request.auth.token && request.auth.token.email in [
            "sarthakgatlewar1805@gmail.com",
            "nidhinetke@gmail.com",
            "vedantgatlewar1@gmail.com",
            "vedantgatlewar2004@gmail.com"
          ]) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'imageUrl', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string &&
             (!('inStock' in data) || data.inStock is bool) &&
             data.createdAt is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'shippingAddress', 'phoneNumber', 'createdAt']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'shipped', 'delivered'] &&
             data.shippingAddress is string && data.shippingAddress.size() > 0 && data.shippingAddress.size() < 1000 &&
             data.phoneNumber is string && data.phoneNumber.size() > 0 && data.phoneNumber.size() < 50 &&
             (!('instructions' in data) || (data.instructions is string && data.instructions.size() < 2000)) &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile (default customer). Admins can create any profile.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'customer') || isAdmin());
                    
      // Users can update their own profile (cannot change role). Admins can update any profile.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      
      // Only admins can create/update/delete products
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Users can read their own orders. Admins can read all orders.
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      
      // Users can create their own orders.
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      
      // Only admins can update orders (e.g., change status).
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      
      // Admins can delete orders
      allow delete: if isAdmin();
    }
  }
}
